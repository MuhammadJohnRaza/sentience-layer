# Sentience Layer v4.0 - Environment Configuration
# Google Antigravity Hackathon Entry

# ============================================
# Google Antigravity Configuration (REQUIRED)
# ============================================
GOOGLE_ANTIGRAVITY_API_KEY=your_antigravity_api_key_here
GOOGLE_ANTIGRAVITY_PROJECT_ID=your_project_id
GOOGLE_ANTIGRAVITY_REGION=us-central1
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# Google Gemini API
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# ============================================
# Application Configuration
# ============================================
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
NODE_PORT=3001
FRONTEND_PORT=3000

# API Configuration
API_BASE_URL=http://localhost:8000
API_TIMEOUT=30000
API_RATE_LIMIT=100

# ============================================
# Database Configuration
# ============================================
# PostgreSQL
DATABASE_URL=postgresql://sentience:sentience123@localhost:5432/sentience_db
POSTGRES_USER=sentience
POSTGRES_PASSWORD=sentience123
POSTGRES_DB=sentience_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Vector Database Configuration
# ============================================
# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=sentience_embeddings

# FAISS
FAISS_INDEX_PATH=./data/faiss_index

# ============================================
# AI/ML Configuration
# ============================================
# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Causal Inference
CAUSAL_MIN_OBSERVATIONS=10
CAUSAL_CONFIDENCE_THRESHOLD=0.7

# Simulation
SIMULATION_DEFAULT_SCENARIOS=1000
SIMULATION_DEFAULT_HORIZON_DAYS=90
SIMULATION_TIMEOUT_SECONDS=60

# ============================================
# Agent Configuration
# ============================================
AGENT_TIMEOUT_SECONDS=30
AGENT_MAX_RETRIES=3
AGENT_CONSENSUS_THRESHOLD=0.7
AGENT_DEBATE_MAX_ROUNDS=5

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC

# ============================================
# N8N Workflow Automation
# ============================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ============================================
# Authentication & Security
# ============================================
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption
ENCRYPTION_KEY=your_32_byte_encryption_key_here
ENCRYPTION_ALGORITHM=AES-256-GCM

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=./logs/sentience.log

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true

# ============================================
# External Integrations (Optional)
# ============================================
# Slack
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@sentiencelayer.ai

# GitHub (for PR integration)
GITHUB_TOKEN=
GITHUB_REPO=

# ============================================
# Feature Flags
# ============================================
ENABLE_DREAM_MODE=true
ENABLE_CAUSAL_INFERENCE=true
ENABLE_SIMULATION=true
ENABLE_REAL_TIME_STREAMING=true
ENABLE_MEMORY_LEARNING=true

# ============================================
# Performance & Scaling
# ============================================
MAX_WORKERS=4
WORKER_TIMEOUT=300
MAX_CONCURRENT_AGENTS=10
CACHE_TTL_SECONDS=3600

# ============================================
# Development & Testing
# ============================================
TESTING=false
MOCK_EXTERNAL_APIS=false
SEED_DATABASE=false

# ============================================
# Notes
# ============================================
# 1. Replace all placeholder values with actual credentials
# 2. Never commit .env file to version control
# 3. Use different values for production environment
# 4. Rotate secrets regularly
# 5. Keep GOOGLE_ANTIGRAVITY_API_KEY secure - it's critical!
