{
  "name": "example_credentials",
  "version": "1.0.0",
  "description": "Example credential template for n8n integrations",
  "credentials": {
    "api_key": {
      "type": "string",
      "required": true,
      "description": "API key for authentication",
      "encrypted": true
    },
    "api_secret": {
      "type": "string",
      "required": true,
      "description": "API secret for authentication",
      "encrypted": true
    },
    "base_url": {
      "type": "string",
      "required": false,
      "description": "Base URL for the API",
      "default": "https://api.example.com"
    },
    "timeout": {
      "type": "number",
      "required": false,
      "description": "Request timeout in milliseconds",
      "default": 30000
    }
  },
  "authentication": {
    "type": "bearer",
    "header": "Authorization",
    "prefix": "Bearer"
  },
  "rate_limiting": {
    "enabled": true,
    "max_requests_per_minute": 60,
    "retry_after_seconds": 60
  }
}